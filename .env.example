# Supabase / Cloud Run Environment Variables

# The connection string to your Supabase PostgreSQL database (Pooler)
# Format: postgresql://postgres:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Set to True for detailed logs
DEBUG=False

# JWT Secret Key — CHANGE THIS IN PRODUCTION!
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_EXPIRY_MINUTES=10080

# Google SSO (get these from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL for post-login redirection
FRONTEND_URL=https://frontend-three-blue-48.vercel.app

# Email Verification (set to False to skip verification during dev)
REQUIRE_VERIFICATION=True

# SMTP Configuration (optional — logs to console if not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@sentinel.dev

# Allowed origins for CORS (your frontend URL)
CORS_ORIGINS=frontend-three-blue-48.vercel.app

# Directory for file storage (relative to app root)
UPLOAD_DIR=data/uploads

# Gemini API Key (if using live OCR)
# GEMINI_API_KEY=your-api-key
